{
  "name": "corepack-version-mismatch",
  "version": "1.0.0",
  "description": "Reproduces AutoFix lockfile update failure: Corepack uses packageManager pnpm@11.15.1 while pnpm enforces devEngines 10.23.0.",
  "license": "ISC",
  "type": "commonjs",
  "main": "index.js",
  "packageManager": "pnpm@11.15.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "10.23.0",
      "onFail": "error"
    }
  },
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "fast-xml-parser": "4.5.0"
  },
  "pnpm": {
    "overrides": {}
  }
}
